# --- Required: Studio /proxy WebSocket tunnel --------------------------
# The MCP container reaches SingleStore by way of a `tunnel` sidecar that
# bridges TCP MySQL to wss://${STUDIO_HOST}/proxy?hostname=&port=, the
# same path the export-org.nu script uses.
STUDIO_HOST=singlestore.guestway.io
REMOTE_DB_HOST=127.0.0.1
REMOTE_DB_PORT=3306

# --- Required: Cloudflare Access service token (daemon-friendly) -------
# Mint in Zero Trust > Access > Service Auth and attach a Service Auth
# policy to the Studio Access application.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Optional: short-lived dev fallback. Use the value of the CF_Authorization
# cookie copied from a logged-in browser session. Expires in ~24h.
# CF_AUTHORIZATION=

# --- Required: SingleStore connection (through the tunnel) -------------
SINGLESTORE_HOST=tunnel
SINGLESTORE_PORT=3306
SINGLESTORE_USER=guestway_mcp_ro
SINGLESTORE_PASSWORD=change-me
SINGLESTORE_DATABASE=core_production_main

# Optional: pool tuning
SINGLESTORE_POOL_LIMIT=5
SINGLESTORE_CONNECT_TIMEOUT_MS=10000

# --- Optional: SingleStore TLS -----------------------------------------
# The reference deployment runs MySQL plaintext inside the EC2 host
# (the export-org.nu script uses --skip-ssl). Flip on when your cluster
# speaks TLS on its MySQL port.
SINGLESTORE_TLS=false
# Override SNI / hostname verification so mysql2 verifies the SingleStore
# certificate against the real cluster name rather than `tunnel`.
# SINGLESTORE_TLS_SERVERNAME=svc-xxxxxxxx.svc.singlestore.com
# Last-resort escape hatch for self-signed clusters. Logs a loud WARN.
# SINGLESTORE_TLS_REJECT_UNAUTHORIZED=true

# --- Optional: HTTP transport (Streamable HTTP) ------------------------
# stdio is always enabled; only flip this on if a remote client
# (e.g. mcp-remote on a laptop) needs to reach the server over HTTP.
MCP_HTTP_ENABLED=true
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8081

# Bearer token for the /mcp endpoint. Required when binding to a
# non-loopback interface. Generate with `openssl rand -hex 32`.
MCP_BEARER_TOKEN=replace-with-32-bytes-of-randomness

# Comma-separated allowlists used for DNS-rebinding protection
# and CORS. Empty by default (deny all browser origins).
MCP_ALLOWED_ORIGINS=
MCP_ALLOWED_HOSTS=

# Per-IP rate limit, requests per minute against /mcp.
MCP_RATE_LIMIT_PER_MIN=120
MCP_BODY_LIMIT=256kb

# --- Logging -----------------------------------------------------------
# trace | debug | info | warn | error | fatal
LOG_LEVEL=info
